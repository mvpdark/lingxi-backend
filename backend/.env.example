# ===========================================================================
# 灵犀后端环境变量示例（多租户 SaaS 纯 API）
#
# 用法：
#   docker compose：cp backend/.env.example .env（放到项目根，与 docker-compose.yml 同目录）
#   Unraid：无需本文件，直接在容器模板（unraid/*.xml）的 Variables 中逐项填写
#
# 所有值均为占位符，请替换为真实值；密钥类严禁提交 git。
# ===========================================================================

# ---------------------------------------------------------------------------
# PostgreSQL 容器配置（供 docker-compose 的 postgres 服务使用）
# ---------------------------------------------------------------------------
POSTGRES_USER=lingxi
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lingxi

# 应用数据库连接串（asyncpg 异步驱动）
#   docker compose：主机名填服务名 postgres（compose 会自动按此插值覆盖，无需手改）
#   Unraid：主机名填 lingxi-postgres（两容器须在同一自定义网络，见 unraid 模板说明）
#   本地开发：127.0.0.1
DATABASE_URL=postgresql+asyncpg://lingxi:CHANGE_ME@postgres:5432/lingxi

# ---------------------------------------------------------------------------
# 认证 / 安全
# ---------------------------------------------------------------------------
# JWT 签名密钥（生产必须设置！），生成方法：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME

# 管理员用户名（首个注册用户自动成为 admin）
ADMIN_USERNAME=admin

# 旧版 API Token（无登录客户端的服务间降级鉴权，可选；不设置则使用代码内默认值）
# API_TOKEN=CHANGE_ME

# ---------------------------------------------------------------------------
# WebDAV 用户文件存储（Unraid NAS）
# ---------------------------------------------------------------------------
WEBDAV_URL=http://192.168.10.8:19798/dav
WEBDAV_USERNAME=lingxi
WEBDAV_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# 计费
# ---------------------------------------------------------------------------
# 计费汇率（1 美元 = 多少人民币）
BILLING_RATE=2.0

# ---------------------------------------------------------------------------
# 运行模式
# ---------------------------------------------------------------------------
# 纯 API 模式：false 时后端不托管前端静态文件（Tauri/Capacitor 客户端直连）
SERVE_FRONTEND=false

# CORS 允许源（逗号分隔；Tauri v2 桌面端示例）
CORS_ORIGINS=tauri://localhost,http://tauri.localhost

# ---------------------------------------------------------------------------
# LLM 对话 API（yunwu，多个 key 用英文逗号分隔自动轮询 + 失败冷却）
# ---------------------------------------------------------------------------
LLM_API_BASE=https://yunwu.ai
# 多个 key 用英文逗号分隔，代码自动 round-robin 轮询，失败自动冷却 60 秒切换
LLM_API_KEY=sk-aaa,sk-bbb,sk-ccc
LLM_MODEL=gpt-5.6-luna

# ---------------------------------------------------------------------------
# 图像生成 API（yunwu 集成 key，与 LLM 共用，无需单独配置 key）
# ---------------------------------------------------------------------------
IMAGE_API_BASE=https://yunwu.ai
IMAGE_MODEL=gpt-image-2

# ---------------------------------------------------------------------------
# Tavily 搜索 API（多个 key 用英文逗号分隔自动轮询）
# ---------------------------------------------------------------------------
# 多个 key 用英文逗号分隔，轮询逻辑同上
TAVILY_API_KEY=tvly-aaa,tvly-bbb

# ---------------------------------------------------------------------------
# 资源目录（可选）
# ---------------------------------------------------------------------------
# 上传/生成图主目录（webdav_cache 为其子目录，WebDAV 同步缓存也落在其下）；
# Docker 内默认 /app/assets，配合缓存 volume 持久化时可设为 /app/assets_cache
# ASSETS_DIR=/app/assets_cache

# 运行期缓存目录（可选；默认 ./cache，一般无需修改）
# CACHE_DIR=/app/cache
